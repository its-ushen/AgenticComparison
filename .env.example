# Copy this file to .env and fill in your API keys

# ==============================================================================
# LLM Provider Configuration
# ==============================================================================

# Provider: "anthropic" (default) or "openai" (for Groq, OpenRouter, Together, etc.)
LLM_PROVIDER=anthropic

# --- Option 1: Anthropic (Claude) ---
ANTHROPIC_API_KEY=sk-ant-xxxxx

# --- Option 2: Groq (fast & cheap) ---
# LLM_PROVIDER=openai
# OPENAI_API_KEY=gsk_xxxxx
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# MODEL_NAME=llama-3.3-70b-versatile
# JUDGE_MODEL=llama-3.1-8b-instant

# --- Option 3: OpenRouter ---
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-or-xxxxx
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# MODEL_NAME=meta-llama/llama-3.1-70b-instruct
# JUDGE_MODEL=meta-llama/llama-3.1-8b-instruct

# ==============================================================================
# Model Settings (optional, defaults shown)
# ==============================================================================

# Agent model (for running the payment agent)
# MODEL_NAME=claude-sonnet-4-20250514

# Judge model (for evaluation)
# JUDGE_MODEL=claude-3-5-haiku-20241022
